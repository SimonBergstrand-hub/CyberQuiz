@using CyberQuiz.UI.ViewModels

<div class="category-list">
    @if (Categories == null || !Categories.Any())
    {
        <p>No categories available</p>
    }
    else
    {
        @for (int i = 0; i < Categories.Count; i++)
        {
            var category = Categories[i];
            bool isEnabled = i == 0 || Categories[i - 1].Percentage >= 80;

            <CategoryCard Category="category"
                          IsEnabled="isEnabled"
                          GoToDetails="GoToDetails" />
        }
    }
</div>

@code {
    [Parameter] public List<CategoryProgressViewModel> Categories { get; set; } = new();
    [Parameter] public EventCallback<int> GoToDetails { get; set; }
}

<style>
    .category-list {
        display: flex;
        gap: 16px;
        flex-wrap: wrap;
    }
</style>