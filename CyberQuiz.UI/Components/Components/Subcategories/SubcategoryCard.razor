@using CyberQuiz.UI.ViewModels

<div class="subcategory-card @(SubCategory.IsUnlocked ? string.Empty : "locked")">

    <div class="subcategory-header">

        <div class="difficulty-name">
            @SubCategory.Name
        </div>

        @if (!SubCategory.IsUnlocked)
        {
            <div class="lock-icon">🔒</div>
        }

    </div>

    <div class="subcategory-stats">
        @SubCategory.CorrectAnswers / @SubCategory.TotalQuestions correct
    </div>

    <div class="progress-wrapper">

        <div class="progress-bar">
            <div class="progress-fill"
                 style="width:@SubCategory.Percentage%">
            </div>
        </div>

        <div class="progress-text">
            @($"{SubCategory.Percentage:0}%")
        </div>

    </div>

    <button class="start-button"
            disabled="@(!SubCategory.IsUnlocked)"
            @onclick="StartQuiz">

        Start Quiz

    </button>

</div>

@code {

    [Parameter] public SubCategoryViewModel SubCategory { get; set; } = default!;

    [Parameter] public EventCallback<int> OnStartQuiz { get; set; }

    private async Task StartQuiz()
    {
        // Pass the actual subcategory DB id to the quiz page so the API can return questions
        await OnStartQuiz.InvokeAsync(SubCategory.Id);
    }

}

<style>

    .subcategory-card {
        background: #1f2937;
        padding: 24px;
        border-radius: 14px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, .35);
        display: flex;
        flex-direction: column;
        gap: 14px;
        transition: .2s;
    }

        .subcategory-card:hover {
            transform: translateY(-3px);
        }

        .subcategory-card.locked {
            opacity: .45;
        }

    .subcategory-header {
        display: flex;
        justify-content: space-between;
    }

    .difficulty-name {
        font-size: 20px;
        font-weight: 600;
        color: white;
    }

    .subcategory-stats {
        color: #9ca3af;
    }

    .progress-wrapper {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .progress-bar {
        flex: 1;
        height: 10px;
        background: #374151;
        border-radius: 6px;
    }

    .progress-fill {
        height: 100%;
        background: linear-gradient(90deg,#22c55e,#4ade80);
    }

    .start-button {
        border: none;
        padding: 10px;
        border-radius: 8px;
        background: #2563eb;
        color: white;
    }

</style>