@using CyberQuiz.UI.ViewModels

@code {
    [Parameter] public QuizQuestionViewModel Question { get; set; }
    [Parameter] public EventCallback<int> OnAnswerSelected { get; set; }

    private async Task SelectAnswer(int answerIndex)
    {
        await OnAnswerSelected.InvokeAsync(answerIndex);
    }

    private string GetAnswerClass(int index)
    {
        if (!Question.IsAnswered) return "";

        if (index == Question.CorrectAnswerIndex) return "correct";
        if (index == Question.SelectedAnswerIndex) return "wrong";

        return "disabled";
    }
}

<div class="question-card slide-in">

    <div class="question-title">
        @Question.QuestionText
    </div>

    <div class="answers-container">

        @for (int i = 0; i < Question.Answers.Count; i++)
        {
            var index = i;

            <button class="answer-card @(GetAnswerClass(index))"
                    @onclick="@(() => SelectAnswer(index))"
                    disabled="@Question.IsAnswered">

                <div class="answer-letter">
                    @(Convert.ToChar(65 + i))
                </div>

                <div class="answer-text">
                    @Question.Answers[i]
                </div>

            </button>
        }

    </div>

</div>

<style>

.question-card{
    background:#1f2937;
    padding:35px;
    border-radius:14px;
    color:white;
    box-shadow:0 10px 25px rgba(0,0,0,.4);
}

.question-title{
    font-size:22px;
    font-weight:600;
    margin-bottom:25px;
}

.answers-container{
    display:flex;
    flex-direction:column;
    gap:12px;
}

.answer-card{

    display:flex;
    align-items:flex-start;

    gap:16px;

    padding:16px;

    border-radius:10px;

    border:none;

    background:#374151;
    color:white;

    text-align:left;

    transition:all .2s ease;
}

.answer-card:hover{
    transform:translateY(-2px);
    background:#4b5563;
}

.answer-letter{

    min-width:34px;
    height:34px;

    display:flex;
    align-items:center;
    justify-content:center;

    border-radius:8px;

    background:#111827;

    font-weight:bold;
}

.answer-text{
    flex:1;
    line-height:1.4;
    word-break:break-word;
}

.answer-card.correct{
    background:#16a34a;
}

.answer-card.wrong{
    background:#dc2626;
}

.answer-card.disabled{
    opacity:.5;
}

.slide-in{
    animation:slideIn .35s ease;
}

@@keyframes slideIn{
    from{
        opacity:0;
        transform:translateX(20px);
    }
    to{
        opacity:1;
        transform:translateX(0);
    }
}

</style>