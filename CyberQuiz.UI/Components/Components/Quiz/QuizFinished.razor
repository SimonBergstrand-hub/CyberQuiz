@code {
    [Parameter] public int CorrectAnswers { get; set; }
    [Parameter] public int TotalQuestions { get; set; }
    [Parameter] public EventCallback OnBackClicked { get; set; }

}

<div class="quiz-finished-card">

    <h1 class="finish-title">
        Quiz Completed
    </h1>

    <div class="score">
        @CorrectAnswers / @TotalQuestions
    </div>

    @{
        var percent = (double)CorrectAnswers / TotalQuestions * 100;
    }

    <div class="finish-progress">

        <div class="finish-progress-bar"
             style="width:@percent%">
        </div>

    </div>



    <button class="finish-button"
            @onclick="() => OnBackClicked.InvokeAsync()">

        Back to Categories

    </button>

</div>

<style>

    .quiz-finished-card {
        background: #1f2937;
        padding: 40px;
        border-radius: 16px;
        text-align: center;
        max-width: 500px;
        margin: auto;
        color: white;
        box-shadow: 0 10px 25px rgba(0,0,0,.4);
    }

    .finish-title {
        font-size: 32px;
        margin-bottom: 10px;
    }

    .score {
        font-size: 28px;
        font-weight: 600;
        margin-bottom: 20px;
    }

    .finish-progress {
        height: 16px;
        background: #374151;
        border-radius: 10px;
        overflow: hidden;
        margin-bottom: 20px;
    }

    .finish-progress-bar {
        height: 100%;
        background: linear-gradient(90deg,#22c55e,#4ade80);
    }



    .finish-button {
        padding: 12px 22px;
        border: none;
        border-radius: 8px;
        background: #2563eb;
        color: white;
        font-size: 16px;
        transition: .2s;
    }

        .finish-button:hover {
            background: #1d4ed8;
        }

</style>