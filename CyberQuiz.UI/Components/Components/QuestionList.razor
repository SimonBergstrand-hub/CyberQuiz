@using CyberQuiz.UI.ViewModels
@code {
    [Parameter] public List<QuizQuestionViewModel> Questions { get; set; }
    [Parameter] public int CurrentIndex { get; set; }
    [Parameter] public EventCallback<int> OnSelectQuestion { get; set; }

    private void SelectQuestion(int index)
    {
        OnSelectQuestion.InvokeAsync(index);
    }
}

<div class="question-sidebar">
    @for (int i = 0; i < Questions.Count; i++)
    {
        var q = Questions[i];

        <div class="question-indicator @(GetIndicatorClass(q))" @onclick="() => SelectQuestion(i)">
            Question @(i + 1)
            @if (q.IsAnswered)
            {
                <span>@(q.IsCorrect ? "✔" : "✖")</span>
            }
        </div>
    }
</div>

@code {
    private string GetIndicatorClass(QuizQuestionViewModel q)
    {
        if (!q.IsAnswered) return "";
        return q.IsCorrect ? "correct" : "wrong";
    }
}

<style>
    .question-sidebar {
        width: 200px;
    }

    .question-indicator {
        padding: 8px;
        border: 1px solid #555;
        margin-bottom: 5px;
        cursor: pointer;
        color: white;
    }

    .question-indicator.correct {
        background: #22c55e;
    }

    .question-indicator.wrong {
        background: #ef4444;
    }
</style>