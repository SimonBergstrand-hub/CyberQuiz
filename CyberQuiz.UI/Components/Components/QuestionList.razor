@using CyberQuiz.UI.ViewModels
@using CyberQuiz.UI.Components
<div class="question-sidebar">
    @for (int i = 0; i < Questions.Count; i++)
    {
        var q = Questions[i];
        <div class="question-indicator @(GetIndicatorClass(q))"
             @onclick="@(() => OnSelectQuestion.InvokeAsync(i))">
            Question @(i + 1)
            @if (q.IsAnswered)
            {
                <span>@(q.IsCorrect ? "✔" : "✖")</span>
            }
        </div>
    }
</div>

@code {
    [Parameter] public List<QuizQuestionViewModel> Questions { get; set; } = new();
    [Parameter] public int CurrentIndex { get; set; }
    [Parameter] public EventCallback<int> OnSelectQuestion { get; set; }

    private string GetIndicatorClass(QuizQuestionViewModel q)
        => !q.IsAnswered ? "" : (q.IsCorrect ? "correct" : "wrong");
}