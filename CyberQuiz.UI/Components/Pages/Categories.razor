@page "/categories"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@inject NavigationManager NavigationManager
@inject CyberQuiz.Services.CategoryService CategoryService
@using CyberQuiz.UI.Components.Components
@using CyberQuiz.UI.ViewModels


<CategoryList Categories="@categories" GoToDetails="@HandleGoToDetails" />

@code {
    private List<CategoryProgressViewModel> categories = new();

    protected override async Task OnInitializedAsync()
    {
        categories = await CategoryService.GetUserCategoryProgressAsync();
    }

    private Task HandleGoToDetails(int categoryId)
    {
        NavigationManager.NavigateTo($"/subcategory/{categoryId}");
        return Task.CompletedTask;
    }
}   