@page "/categories"
@rendermode InteractiveServer

@using CyberQuiz.UI.Components.Components.Categories
@using CyberQuiz.UI.Services
@using CyberQuiz.UI.ViewModels
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]

@inject NavigationManager NavigationManager
@inject CategoryService CategoryService

<CategoryList Categories="@categories" GoToDetails="@HandleGoToDetails" />

@code {

    private List<CategoryProgressViewModel> categories = new();

    protected override async Task OnInitializedAsync()
    {
        // EDIT: Load categories from API
        categories = await CategoryService.GetCategoriesAsync();
    }

    private Task HandleGoToDetails(int categoryId)
    {
        NavigationManager.NavigateTo($"/subcategory/{categoryId}");
        return Task.CompletedTask;
    }

}