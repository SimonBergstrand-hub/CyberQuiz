@page "/categories"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@implements IDisposable

@inject NavigationManager NavigationManager
@inject CyberQuiz.Services.CategoryService CategoryService
@inject CyberQuiz.Services.SubCategoryService SubCategoryService
@using CyberQuiz.UI.Components.Components
@using CyberQuiz.UI.ViewModels


<CategoryList Categories="@categories" GoToDetails="@HandleGoToDetails" />

@code {
    private List<CategoryProgressViewModel> categories = new();

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to progress changes so the categories page updates when a quiz is finished
        SubCategoryService.ResultSaved += OnResultSaved;
    }

    protected override async Task OnParametersSetAsync()
    {
        // Always refresh when the component becomes active / parameters change
        categories = await CategoryService.GetUserCategoryProgressAsync();
        await base.OnParametersSetAsync();
    }

    private async void OnResultSaved()
    {
        try { Console.WriteLine("[Categories] OnResultSaved invoked"); } catch { }
        categories = await CategoryService.GetUserCategoryProgressAsync();
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        SubCategoryService.ResultSaved -= OnResultSaved;
    }

    private Task HandleGoToDetails(int categoryId)
    {
        NavigationManager.NavigateTo($"/subcategory/{categoryId}");
        return Task.CompletedTask;
    }
}   