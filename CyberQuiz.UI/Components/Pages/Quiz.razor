@page "/quiz/{CategoryId:int}/{SubCategoryId:int}"

@using CyberQuiz.UI.Services
@using CyberQuiz.UI.Components.Components.Quiz
@using CyberQuiz.UI.ViewModels
@using Microsoft.AspNetCore.Authorization

@attribute [Authorize]
@rendermode InteractiveServer

@inject QuizService QuizService
@inject ProgressService ProgressService
@inject NavigationManager NavigationManager

<div class="quiz-container">

    @if (!quizFinished)
    {
        <CancelQuizButton OnCancelQuiz="ReturnToSubcategory" />
    }

    <QuizProgress CurrentIndex="@currentIndex"
                  TotalQuestions="@questions.Count"
                  AnsweredCount="@questions.Count(q => q.IsAnswered)"
                  Visible="!quizFinished" />

    <div class="quiz-layout">

        <QuestionList Questions="@questions"
                      CurrentIndex="@currentIndex"
                      QuizFinished="@quizFinished"
                      OnSelectQuestion="HandleSelectQuestion" />

        <div class="quiz-main-area">

            <QuizMainArea CurrentQuestion="@currentQuestion"
                          QuizFinished="@quizFinished"
                          CorrectAnswers="@correctAnswers"
                          QuestionsCount="@questions.Count"
                          OnAnswerSelected="HandleAnswerSelected"
                          OnBackClicked="ReturnToSubcategory" />

        </div>

    </div>

</div>

@code {

    [Parameter] public int CategoryId { get; set; }
    [Parameter] public int SubCategoryId { get; set; }

    private List<QuizQuestionViewModel> questions = new();
    private int currentIndex = 0;

    private QuizQuestionViewModel? currentQuestion =>
        questions.ElementAtOrDefault(currentIndex);

    private bool quizFinished = false;

    private int correctAnswers = 0;

    protected override async Task OnInitializedAsync()
    {
        // EDIT: Load questions from API using the subcategory id
        questions = await QuizService.GetQuestionsAsync(SubCategoryId);
    }

    async Task HandleAnswerSelected(int optionId)
    {
        if (currentQuestion == null)
            return;

        // EDIT: Submit answer to API
        currentQuestion.SelectedOptionId = optionId;

        var result = await ProgressService
            .SubmitAnswerAsync(currentQuestion.Id, optionId);

        if (result != null)
        {
            currentQuestion.CorrectOptionId = result.CorrectOptionId;

            // EDIT: Correctness now comes from API response
            if (result.IsCorrect)
                correctAnswers++;
        }

        await CheckQuizCompletion();

        StateHasChanged();

        // Small delay so the user sees the feedback, then advance to next question
        await Task.Delay(800);

        if (!quizFinished && currentIndex < questions.Count - 1)
        {
            currentIndex++;
        }

        StateHasChanged();
    }

    void HandleSelectQuestion(int index)
    {
        currentIndex = index;
    }

    async Task CheckQuizCompletion()
    {
        // EDIT: Quiz finishes when all questions answered
        if (questions.All(q => q.IsAnswered))
        {
            quizFinished = true;
        }
    }

    void ReturnToSubcategory()
    {
        NavigationManager.NavigateTo($"/subcategory/{CategoryId}");
    }

}

<style>
    .quiz-container {
        max-width: 1100px;
        margin: auto;
    }

    .quiz-layout {
        display: flex;
        gap: 30px;
    }

    .quiz-main-area {
        flex: 1;
        min-height: 420px;
    }
</style>