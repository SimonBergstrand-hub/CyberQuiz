@page "/subcategory/{CategoryId:int}"
@using CyberQuiz.Services
@using CyberQuiz.UI.ViewModels
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

@inject NavigationManager NavigationManager
@inject SubCategoryService SubCategoryService

@rendermode InteractiveServer

<h2 class="subcategory-title">
    Subcategories
</h2>

@if (subCategories == null)
{
    <p>Loading...</p>
}
else
{
    <div class="subcategory-grid">

        @foreach (var sub in subCategories)
        {
            <div class="subcategory-card @(sub.IsUnlocked ? "" : "locked")">

                <div class="subcategory-header">

                    <div class="difficulty-name">
                        @sub.DifficultyName
                    </div>

                    @if (!sub.IsUnlocked)
                    {
                        <div class="lock-icon">
                            🔒
                        </div>
                    }

                </div>

                <div class="subcategory-stats">

                    <div class="score">
                        @sub.CorrectAnswers / @sub.TotalQuestions correct
                    </div>

                </div>

                <div class="progress-wrapper">

                    <div class="progress-bar">

                        <div class="progress-fill"
                             style="width:@sub.Percentage%">
                        </div>

                    </div>

                    <div class="progress-text">
                        @($"{sub.Percentage:0}%")
                    </div>

                </div>

                <button class="start-button"
                        disabled="@(!sub.IsUnlocked)"
                        @onclick="() => StartQuiz(sub.DifficultyIndex)">

                    Start Quiz

                </button>

            </div>
        }

    </div>
}

@code {

    [Parameter] public int CategoryId { get; set; }

    private List<SubCategoryViewModel>? subCategories;

    protected override async Task OnInitializedAsync()
    {
        subCategories = await SubCategoryService.GetSubCategoriesAsync(CategoryId);
    }

    void StartQuiz(int subIndex)
    {
        NavigationManager.NavigateTo($"/quiz/{CategoryId}/{subIndex}");
    }

}

<style>

.subcategory-title{
    color:white;
    margin-bottom:30px;
}

.subcategory-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
    gap:20px;
}

.subcategory-card{

    background:#1f2937;
    padding:24px;
    border-radius:14px;

    box-shadow:0 10px 25px rgba(0,0,0,.35);

    display:flex;
    flex-direction:column;
    gap:14px;

    transition:.2s;
}

.subcategory-card:hover{
    transform:translateY(-3px);
}

.subcategory-card.locked{
    opacity:.45;
}

.subcategory-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
}

.difficulty-name{
    font-size:20px;
    font-weight:600;
    color:white;
}

.lock-icon{
    font-size:18px;
}

.subcategory-stats{
    color:#9ca3af;
    font-size:14px;
}

.progress-wrapper{
    display:flex;
    align-items:center;
    gap:10px;
}

.progress-bar{
    flex:1;
    height:10px;
    background:#374151;
    border-radius:6px;
    overflow:hidden;
}

.progress-fill{
    height:100%;
    background:linear-gradient(90deg,#22c55e,#4ade80);
}

.progress-text{
    color:#9ca3af;
    font-size:13px;
}

.start-button{

    margin-top:10px;

    border:none;
    padding:10px;

    border-radius:8px;

    background:#2563eb;
    color:white;

    transition:.2s;
}

.start-button:hover{
    background:#1d4ed8;
}

</style>